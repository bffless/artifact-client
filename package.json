{
  "name": "@bffless/artifact-client",
  "version": "1.0.0",
  "description": "Shared API client for BFFLESS artifact upload and download",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bffless/artifact-client.git"
  },
  "keywords": [
    "bffless",
    "artifact",
    "upload",
    "download",
    "github-actions"
  ],
  "author": "BFFLESS",
  "license": "O'Saasy",
  "dependencies": {
    "@actions/core": "^1.10.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
